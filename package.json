{
  "name": "tu-oficio",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n back,front -c blue,green \"npm run start:back\" \"PORT=3001 npm run start:front\"",
    "start": "npm run start:back",
    "build": "npm run build:front && npm run build:back",
    "start:back": "npm run start --workspace=backend",
    "start:front": "npm run start --workspace=frontend",
    "build:back": "npm run build --workspace=backend",
    "build:front": "npm run build --workspace=frontend",
    "test:back": "npm run test --workspace=backend",
    "test:e2e": "npm run test:e2e --workspace=backend",
    "test:front": "npm run test --workspace=frontend",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
